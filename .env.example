# Anthropic API key for the prerender + strategist + enhancer
ANTHROPIC_API_KEY=sk-ant-...

# Peec AI REST API — get from https://app.peec.ai → Account settings
# In dev, set PEEC_FIXTURE=examples/founder-mvp/peec-fixture.json to skip the network
PEEC_API_KEY=
PEEC_API_URL=https://api.peec.ai/customer/v1
PEEC_FIXTURE=

# Default project to operate on
PEEC_PROJECT_ID=

# Optional model override; defaults to claude-sonnet-4-6
LTSEO_MODEL=
