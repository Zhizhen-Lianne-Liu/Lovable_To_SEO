# =============================================================================
# Lovable_To_SEO — single source of truth for all module env vars.
# Copy to .env and fill in. Module-local .env files are NOT used.
# =============================================================================

# --- Peec AI ---------------------------------------------------------------
# Get from https://app.peec.ai → Account settings → API keys (company-scoped, skc-...)
PEEC_API_KEY=
PEEC_API_URL=https://api.peec.ai/customer/v1

# Default project for orchestrator / strategist (can be overridden by --project-id)
PEEC_PROJECT_ID=

# Dev fixture — skip the Peec network and use a local JSON instead
PEEC_FIXTURE=

# --- Anthropic (root pipeline + anton's curator/aggregator/sub-agents) ----
ANTHROPIC_API_KEY=sk-ant-...
LTSEO_MODEL=                      # optional model override; defaults to claude-sonnet-4-6
CLAUDE_AGENT_MODEL=claude-sonnet-4-6

# --- Gemini (optional alternative provider for anton) ---------------------
GEMINI_API_KEY=

# --- DataForSEO (anton: keyword overlap stage) ----------------------------
# Get at https://app.dataforseo.com/api-access (account verification required)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- GitHub (anton: stage 1 Lovable repo import) --------------------------
# Optional — without it, GitHub limits unauth requests to 60/hr; with it 5000/hr
GITHUB_TOKEN=

# --- Tavily (peec-onboarder: competitor discovery) ------------------------
# Get at https://app.tavily.com → API
TAVILY_API_KEY=tvly-dev-...

# --- Python FastAPI service (src/lovable_to_seo/) -------------------------
LTSEO_API_HOST=0.0.0.0
LTSEO_API_PORT=8000
