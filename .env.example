# =============================================================================
# lovabletoseo — single source of truth for all env vars.
# Copy to .env and fill in. Both .env and .env.local are loaded (local wins).
# =============================================================================

# --- Anthropic --------------------------------------------------------------
ANTHROPIC_API_KEY=
PROFILE_MODEL=claude-sonnet-4-6
CURATOR_MODEL=claude-opus-4-7
SUBAGENT_MODEL=claude-sonnet-4-6
AGGREGATOR_MODEL=claude-opus-4-7

# --- Gemini -----------------------------------------------------------------
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Tavily -----------------------------------------------------------------
# https://app.tavily.com → API
TAVILY_API_KEY=

# --- Peec AI ----------------------------------------------------------------
# https://app.peec.ai → Account settings → API keys (skc-...)
PEEC_API_KEY=
PEEC_API_URL=https://api.peec.ai/customer/v1
PEEC_PROJECT_ID=

# Dev fixture — skip the Peec network and use a local JSON instead
PEEC_FIXTURE=

# --- DataForSEO -------------------------------------------------------------
# https://app.dataforseo.com/api-access (account verification required)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- GitHub App (round-trip PR back to user's Lovable repo) -----------------
# Register a personal GitHub App with: Contents r/w, Pull requests r/w, Metadata r.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Personal-access fallback for unauthenticated GitHub reads (60→5000 req/hr).
GITHUB_TOKEN=

# --- Demo mode --------------------------------------------------------------
# When set to "baked", the landing's POST /api/scan returns examples/founder-mvp/.
DEMO_MODE=
