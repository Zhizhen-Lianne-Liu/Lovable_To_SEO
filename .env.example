# Anthropic API key for the rewriter
ANTHROPIC_API_KEY=sk-ant-...

# Peec AI MCP — OAuth bearer token (after browser auth)
# In dev, set PEEC_FIXTURE=examples/attio/peec-fixture.json to skip the network
PEEC_MCP_URL=https://api.peec.ai/mcp
PEEC_OAUTH_TOKEN=
PEEC_FIXTURE=

# Default project to operate on (from list_projects)
PEEC_PROJECT_ID=

# Optional model override; defaults to claude-sonnet-4-6
LTSEO_MODEL=
