# =============================================================================
# domain-peec-enrichment — single source of truth for all env vars in this folder.
# Copy to .env and fill in. Both ts/ and py/ read from this one file.
# =============================================================================

# --- Peec AI ---------------------------------------------------------------
# Get from https://app.peec.ai → Account settings → API keys (company-scoped, skc-...)
PEEC_API_KEY=
PEEC_API_URL=https://api.peec.ai/customer/v1

# Default project (or_<uuid>). Grab from any project page URL in the Peec dashboard.
PEEC_PROJECT_ID=

# --- Anthropic --------------------------------------------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Gemini (optional alternative LLM provider) -----------------------------
# Free tier hits 429 on parallel calls — use only on a paid plan.
GEMINI_API_KEY=

# --- DataForSEO -------------------------------------------------------------
# https://app.dataforseo.com/api-access (account verification required)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Tavily -----------------------------------------------------------------
# https://app.tavily.com → API. Dev tier gives 1000 free searches/month.
TAVILY_API_KEY=

# --- GitHub (optional, for stage 1 Lovable repo import) --------------------
# Without it, GitHub limits unauth requests to 60/hr; with it, 5000/hr.
GITHUB_TOKEN=
