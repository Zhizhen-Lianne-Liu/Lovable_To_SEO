{
  "name": "lovabletoseo",
  "version": "0.2.0",
  "description": "The AI marketer for Lovable founders. Clone a Lovable repo, fix technical SEO, run Peec+Tavily intelligence, apply marketing skills, and PR back to GitHub.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "core:dev": "npm --workspace @lovabletoseo/core run dev",
    "core:build": "npm --workspace @lovabletoseo/core run build",
    "core:typecheck": "npm --workspace @lovabletoseo/core run typecheck",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
