{
  "name": "lovabletoseo",
  "version": "0.2.0",
  "description": "The AI marketer for Lovable founders. Clone a Lovable repo, fix technical SEO, run Peec+Tavily intelligence, apply marketing skills, and PR back to GitHub.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm --workspace @lovabletoseo/core run dev",
    "build": "npm --workspace @lovabletoseo/core run build",
    "typecheck": "npm --workspace @lovabletoseo/core run typecheck",
    "smoke:enrich": "npm --workspace @lovabletoseo/core run smoke:enrich --",
    "validate:smoke": "npm --workspace @lovabletoseo/core run validate:smoke --"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
