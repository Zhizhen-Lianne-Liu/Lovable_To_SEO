# GitHub personal access token (no scopes needed for public repos).
# Without it, GitHub limits unauthenticated requests to 60/hr.
# With it, you get 5000/hr. Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# Peec AI API key. Used to submit prompts and read ranking results.
# Get one from your Peec AI dashboard. Format: skc-...
PEEC_API_KEY=

# DataForSEO Basic-auth credentials. Used by the competitors module
# to fetch competitor domains and ranked keywords.
# Get them at https://app.dataforseo.com/api-access
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# LLM provider keys. The sub-agents auto-detect:
# - if GEMINI_API_KEY is set, use Gemini (default for cost)
# - else if ANTHROPIC_API_KEY is set, use Claude
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
